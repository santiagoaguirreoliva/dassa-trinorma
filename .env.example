# Renombrar a .env y completar

NODE_ENV=development
PORT=3000

# PostgreSQL — Railway provee esto automáticamente en deploy
DATABASE_URL=postgresql://user:pass@localhost:5432/dassa_sgi

# JWT Secret — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_esto_por_un_secret_seguro_de_64_chars

# CORS
CORS_ORIGIN=http://localhost:5173

# Dev
LOG_QUERIES=false
