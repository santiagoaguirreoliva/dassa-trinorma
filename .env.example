# Renombrar a .env y completar todos los valores antes de levantar el servidor.
# El sistema usa 21 variables — todas las que están sin "(opcional)" son necesarias.

# ─── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4001

# URL pública del backend (se usa en emails, SSO callbacks, etc.)
APP_URL=http://localhost:4001
APP_HOST=localhost

# ─── PostgreSQL — Railway provee DATABASE_URL automáticamente en deploy ───
DATABASE_URL=postgresql://user:pass@localhost:5432/dassa_sgi
LOG_QUERIES=false

# ─── JWT ─────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_esto_por_un_secret_seguro_de_64_chars

# ─── CORS (lista separada por comas) ─────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:4001

# ─── SMTP (mailer.cjs — recordatorios, intimaciones, reset password) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alerts@dassa.com.ar
SMTP_PASS=app_password_de_gmail
SMTP_FROM="DASSA SGI <alerts@dassa.com.ar>"
MAIL_BCC=santiago@dassa.com.ar

# ─── Cron jobs ──────────────────────────────────────────────
# Bearer token usado por endpoints /api/cron/* (si se exponen los cron como HTTP)
CRON_SECRET=token_para_endpoints_de_cron

# ─── SSO con Smart DASSA Apps (app madre) ───────────────────
DASSA_APPS_SSO_URL=http://localhost:3000
DASSA_APPS_SSO_SECRET=hmac_compartido_con_SDA

# ─── IA — Auditor IA y Triny ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Ollama local (fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
